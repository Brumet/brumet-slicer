{
  "name": "brumet-slicer",
  "version": "1.1.0",
  "description": "Cotizador de impresion 3D Brumet",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "publish": "electron-builder --win --publish always",
    "codigos": "node generar-codigos.js"
  },
  "build": {
    "appId": "com.brumet.slicer",
    "productName": "Brumet Slicer",
    "publish": {
      "provider": "github",
      "owner": "Brumet",
      "repo": "brumet-slicer",
      "private": false
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Brumet Slicer"
    },
    "files": [
      "main.js",
      "index.html",
      "viewer.html",
      "slicer-bambu.js",
      "leer-gcode.js",
      "licenses.json",
      "assets/**",
      "perfiles/**",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "perfiles/",
        "to": "perfiles/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "BambuStudio/",
        "to": "../BambuStudio/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.3",
    "sharp": "^0.34.5",
    "three": "^0.176.0"
  }
}
